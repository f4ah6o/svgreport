# ======================================
# Core kintone connection
# ======================================
KINTONE_BASE_URL=https://example.cybozu.com
KINTONE_API_TOKEN=token_template_app,token_job_app,token_source_app

# ======================================
# Report API server
# ======================================
REPORT_API_HOST=127.0.0.1
REPORT_API_PORT=8790
REPORT_API_AUTH_TOKEN=replace-with-strong-bearer-token

# ======================================
# Worker runtime
# ======================================
REPORT_WORKER_POLL_MS=5000
REPORT_WORKER_RETRY_BACKOFF_MS=10000
REPORT_PLAYWRIGHT_CMD=playwright

# ======================================
# kintone app IDs
# ======================================
REPORT_TEMPLATE_APP_ID=100
REPORT_JOB_APP_ID=200

# ======================================
# Job app field mapping
# (change if your app uses different field codes)
# ======================================
REPORT_JOB_FIELD_JOB_ID=job_id
REPORT_JOB_FIELD_IDEMPOTENCY_KEY=idempotency_key
REPORT_JOB_FIELD_STATUS=status
REPORT_JOB_FIELD_APP_ID=source_app_id
REPORT_JOB_FIELD_RECORD_ID=source_record_id
REPORT_JOB_FIELD_TEMPLATE_ACTION_CODE=template_action_code
REPORT_JOB_FIELD_TEMPLATE_CODE=template_code
REPORT_JOB_FIELD_TEMPLATE_VERSION=template_version
REPORT_JOB_FIELD_REQUESTED_BY=requested_by
REPORT_JOB_FIELD_ATTEMPTS=attempts
REPORT_JOB_FIELD_MAX_ATTEMPTS=max_attempts
REPORT_JOB_FIELD_NEXT_RUN_AT=next_run_at
REPORT_JOB_FIELD_STARTED_AT=started_at
REPORT_JOB_FIELD_FINISHED_AT=finished_at
REPORT_JOB_FIELD_INPUT_SNAPSHOT_JSON=input_snapshot_json
REPORT_JOB_FIELD_RENDER_DEBUG_JSON=render_debug_json
REPORT_JOB_FIELD_OUTPUT_PDF=output_pdf
REPORT_JOB_FIELD_OUTPUT_SVG_ZIP=rendered_svgs_zip
REPORT_JOB_FIELD_ERROR_CODE=error_code
REPORT_JOB_FIELD_ERROR_MESSAGE=error_message

# ======================================
# Template app field mapping
# (change if your app uses different field codes)
# ======================================
REPORT_TEMPLATE_FIELD_TEMPLATE_CODE=template_code
REPORT_TEMPLATE_FIELD_VERSION=version
REPORT_TEMPLATE_FIELD_SOURCE_APP_ID=source_app_id
REPORT_TEMPLATE_FIELD_STATUS=status
REPORT_TEMPLATE_FIELD_PUBLISHED_SEQ=published_seq
REPORT_TEMPLATE_FIELD_ACTION_CODE=action_code
REPORT_TEMPLATE_FIELD_TEMPLATE_JSON=template_json
REPORT_TEMPLATE_FIELD_PAGE1_SVG=page_1_svg
REPORT_TEMPLATE_FIELD_PAGE_FOLLOW_SVG=page_follow_svg
